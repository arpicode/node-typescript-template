{
  "name": "node-typescript-template",
  "version": "1.1.0",
  "description": "NodeJS/TypeScript project",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm tsx watch src/main.ts",
    "build": "pnpm clean && pnpm tsc --project tsconfig.build.json",
    "typecheck": "pnpm tsc --project tsconfig.json",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint . --fix",
    "format": "pnpm prettier . --write",
    "format:check": "pnpm prettier . --check",
    "test": "pnpm vitest run",
    "test:ui": "pnpm vitest --ui",
    "test:watch": "pnpm vitest",
    "test:coverage": "pnpm vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "clean:install": "rm -rf node_modules && pnpm install",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "author": "arpicode",
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}